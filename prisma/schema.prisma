generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Partner {
  id          String    @id @default(cuid())
  name        String
  accessCode  String    @unique
  students    Student[]
}

model Student {
  id          String     @id @default(cuid())
  name        String
  partnerId   String
  partner     Partner    @relation(fields: [partnerId], references: [id])
  progress    Progress[]
}

model Vocab {
  id        String   @id @default(cuid())
  level     Int      
  session   Int      
  hanzi     String   
  pinyin    String
  meaning   String
}

model Progress {
  id         String   @id @default(cuid())
  studentId  String
  vocabId    String
  isDone     Boolean  @default(false)
  createdAt  DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [id])
}