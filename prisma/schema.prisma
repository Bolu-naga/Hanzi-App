generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Akun Guru / Laoshi
model Teacher {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String 
  dailyNote String @default("Halo! Terus berlatih ya. Pilih menu Ruang Kelas di samping untuk mulai belajar dan menambah poin Hanzi-mu hari ini!")
}

// Akun Murid (Dibuat oleh Guru)
model Student {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String 
  progress Progress[]
  attendances Attendance[]
}

model Vocab {
  id        String   @id @default(cuid())
  level     Int
  session   Int
  hanzi     String
  pinyin    String
  meaning   String
}

model Progress {
  id         String   @id @default(cuid())
  studentId  String
  vocabId    String
  isDone     Boolean  @default(false)
  createdAt  DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [id])
}

model Attendance {
  id        String   @id @default(cuid())
  studentId String
  date      String   // Format YYYY-MM-DD biar gampang difilter
  status    String   // 'Hadir', 'Izin', 'Sakit', 'Alpa'
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date]) 
}